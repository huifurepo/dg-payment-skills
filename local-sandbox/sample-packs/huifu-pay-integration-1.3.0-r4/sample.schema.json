{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "contract_bundle",
    "sample_id",
    "source_type",
    "authorization",
    "deidentification",
    "endpoint",
    "scenario_id",
    "request",
    "responses",
    "assertions",
    "sample_sha256"
  ],
  "properties": {
    "assertions": {
      "type": "object"
    },
    "authorization": {
      "required": [
        "status",
        "approved_by",
        "approved_at"
      ],
      "type": "object"
    },
    "contract_bundle": {
      "const": "huifu-pay-integration-1.3.0-r4"
    },
    "deidentification": {
      "required": [
        "status",
        "method",
        "checked_at"
      ],
      "type": "object"
    },
    "endpoint": {
      "required": [
        "id",
        "method",
        "path"
      ],
      "type": "object"
    },
    "request": {
      "required": [
        "data"
      ],
      "type": "object"
    },
    "responses": {
      "required": [
        "sync"
      ],
      "type": "object"
    },
    "sample_id": {
      "pattern": "^[a-z0-9][a-z0-9_-]{2,80}$",
      "type": "string"
    },
    "sample_sha256": {
      "pattern": "^[a-f0-9]{64}$",
      "type": "string"
    },
    "schema_version": {
      "const": "1.0"
    },
    "source_type": {
      "enum": [
        "deidentified_production",
        "deidentified_joint_debug"
      ]
    }
  },
  "type": "object"
}
